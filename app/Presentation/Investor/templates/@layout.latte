<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{block title}Smart Funds — Portfolio{/block}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <span class="navbar-brand">Smart Funds</span>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" n:href="Dashboard:default">Moje portfolio</a>
                <a class="nav-link" n:href=":Front:Sign:out">Odhlásit se</a>
            </div>
        </div>
    </nav>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <main class="container">
        {foreach $flashes as $flash}
        <div class="alert alert-{$flash->type} alert-dismissible fade show mt-3" role="alert">
            {$flash->message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {/foreach}
        {block content}{/block}
    </main>
</body>
</html>
